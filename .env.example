# Copy this file to .env and fill in values as needed.
# .env is gitignored — never commit real credentials.

# --- Ingestion ---
# Local landing zone for raw Parquet/Delta files written by ingestion/load.py
DATA_LANDING_PATH=./data/landing

# Logging verbosity for ingestion (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# --- dbt: Databricks target (production) ---
# Only needed when running `dbt run --target databricks`.
# Leave unset for local/dev/CI, which uses the duckdb target instead.
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=au_energy_pipeline
